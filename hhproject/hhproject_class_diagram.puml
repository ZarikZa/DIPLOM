package "admin_panel.procedure_manager" {
  class "DjangoBackupManager" as admin_panel_procedure_manager_DjangoBackupManager {
    + __init__()
    + set_progress_callback(callback)
    + _update_progress(message, percent = None)
    + create_backup(backup_type = 'database', custom_name = None, user = None)
    + _create_database_backup(base_name, user)
    + _create_media_backup(base_name, user)
    + _create_full_backup(base_name, user)
    + restore_backup(backup_file, user)
    + _restore_database_backup_from_memory(file_content, file_name, user)
    + _restore_full_backup_from_memory(file_content, file_name, user)
    + _restore_media_from_zip(zipf)
    + get_system_info()
    + _get_free_space()
    + _get_database_size()
    + _format_file_size(size_bytes)
    + validate_backup(backup_file)
    + test_connection()
    + _create_media_backup(base_name, user)
    + _create_full_backup(base_name, user)
  }
}

