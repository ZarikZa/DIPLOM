<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:keepScreenOn="true"
        app:keep_content_on_player_reset="true"
        app:resize_mode="zoom"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <TextView
        android:id="@+id/tvForYou"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@drawable/bg_pill"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/video_for_you"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:gravity="end|bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnLike"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_video_action_circle"
            android:contentDescription="@string/video_like_desc"
            android:padding="9dp"
            android:src="@drawable/ic_favorite_border"
            android:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvLikes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="5dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnVacancy"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_video_action_circle"
            android:contentDescription="@string/video_open_vacancy_desc"
            android:padding="10dp"
            android:src="@drawable/ic_eye"
            android:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_video_action_circle"
            android:contentDescription="@string/video_sound_desc"
            android:padding="10dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="@android:color/white" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnPlayPause"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_player_controls"
        android:contentDescription="@string/video_play_pause_desc"
        android:padding="14dp"
        android:src="@android:drawable/ic_media_play"
        android:tint="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingEnd="96dp">

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_apply_button"
            android:text="@string/video_apply_button"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
